{
  "name": "perspeqtive/sulu-media-credits-bundle",
  "description": "Display media credits on your website",
  "minimum-stability": "stable",
  "license": "MIT",
  "type": "sulu-bundle",
  "authors": [
    {
      "name": "PERSPEQTIVE GmbH",
      "email": "mail@perspeqtive.de"
    }
  ],
  "keywords": [
    "sulu",
    "sulu bundle",
    "media",
    "credits",
    "media-credits",
    "bundle",
    "copyright"
  ],
  "require": {
    "php": "^8.3",
    "sulu/sulu": "~2.6"
  },
  "require-dev": {
    "doctrine/persistence": "^3.0",
    "jackalope/jackalope-doctrine-dbal": "^2.0",
    "phpunit/phpunit": "^12",
    "sulu/article-bundle": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "PERSPEQTIVE\\MediaCreditsBundle\\": "src/",
      "PERSPEQTIVE\\MediaCreditsBundle\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
